# Copy this file to .env.local and fill in the values.
# Never commit .env.local or .env to version control.

# Prisma / SQLite — path to your database file
DATABASE_URL="file:./dev.db"

# iron-session encryption password — must be at least 32 random characters
SESSION_SECRET="change-me-to-a-random-32-character-string"

# Node environment
NODE_ENV="development"
